{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Slug",
          "placeholder": "quiet-luxury-interiors"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title"
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "single": "paragraph",
          "allowTargetBlank": true
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category"
        }
      },
      "author_name": {
        "type": "Text",
        "config": {
          "label": "Author name"
        }
      },
      "publish_date": {
        "type": "Timestamp",
        "config": {
          "label": "Publish date"
        }
      },
      "cover_image": {
        "type": "Image",
        "config": {
          "label": "Cover image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "multi": "heading2,heading3,paragraph,strong,em,hyperlink,embed,list-item,o-list-item,image",
          "allowTargetBlank": true
        }
      }
    },
    "SEO": {
      "seo_title": {
        "type": "Text",
        "config": {
          "label": "SEO title"
        }
      },
      "seo_description": {
        "type": "StructuredText",
        "config": {
          "label": "SEO description",
          "single": "paragraph",
          "allowTargetBlank": true
        }
      },
      "seo_keywords": {
        "type": "Text",
        "config": {
          "label": "SEO keywords"
        }
      }
    }
  }
}
